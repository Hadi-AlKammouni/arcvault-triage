# Copy this file to .env and fill in real values. .env is gitignored.

# Groq API — get yours at https://console.groq.com (free tier)
GROQ_API_KEY=

# Webhook.site URL for the "normal queue" destination (used by n8n)
NORMAL_QUEUE_WEBHOOK_URL=

# Webhook.site URL for the "escalation queue" destination
# (can reuse the same Webhook.site URL with a different path, e.g. /escalation)
ESCALATION_QUEUE_WEBHOOK_URL=
